{
  "key": "facialHair",
  "dependsOn": ["gender", "race", "age"],
  "options": ["defaultFacialHair"],
  "rules": [
    {
      "when": { "gender": "female" },
      "effect": { "type": "override", "value": "none" }
    },
    {
      "when": { "age": { "lt": 16 } },
      "effect": { "type": "override", "value": "none" }
    },
    {
      "when": { "race": "orc" },
      "effect": {
        "type": "reweight",
        "multiply": { "beard_full": 2.5, "stubble": 1.3 }
      }
    }
  ]
}
